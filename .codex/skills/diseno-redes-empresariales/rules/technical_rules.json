  "edge_device_tiers": [
    {
      "name": "branch_router_firewall",
      "max_supported_clients": 80,
      "recommended_throughput_mbps": 300,
      "typical_cost": 650,
      "use_when": "Oficina pequena o sucursal con bajo trafico."
    },
    {
      "name": "business_router_firewall",
      "max_supported_clients": 200,
      "recommended_throughput_mbps": 1000,
      "typical_cost": 1800,
      "use_when": "Sede mediana con seguridad perimetral y VPN."
    },
    {
      "name": "enterprise_utm_firewall",
      "max_supported_clients": 500,
      "recommended_throughput_mbps": 2500,
      "typical_cost": 5200,
      "use_when": "Sede corporativa, alto trafico, inspeccion y HA."
    },
    {
      "name": "campus_edge_cluster",
      "max_supported_clients": 1200,
      "recommended_throughput_mbps": 10000,
      "typical_cost": 16000,
      "use_when": "Campus o alta densidad con multiples enlaces y HA."
    }
  ],
  "switching": {
    "access_switch_port_options": [24, 48],
    "port_reserve_factor": 1.2,
    "poe_reserve_factor": 1.15,
    "distribution_required_when_floors_gte": 2,
    "distribution_required_when_access_switches_gte": 3,
    "l3_core_required_when_vlans_gte": 4,
    "costs": {
      "access_24_poe": 900,
      "access_48_poe": 1700,
      "distribution_l3": 3200,
      "core_l3_pair": 8500
    }
  },
  "wireless": {
    "ap_cost_by_budget": {"low": 180, "medium": 420, "high": 750},
    "controller_recommended_when_ap_count_gte": 4,
    "controller_cost": 900,
    "load_balancing_recommended_when_ap_count_gte": 3,
    "fast_roaming_required_for_services": ["voice", "video", "pos", "ot_control"]
  },
  "segmentation": {
    "base_vlans": ["management", "corporate", "guest"],
    "device_vlans": {
      "iot": "iot",
      "phones": "voice",
      "cameras": "security",
      "printers": "services",
      "servers": "server"
    },
    "critical_service_vlans": {
      "voice": "voice",
      "video": "collaboration",
      "erp": "business_critical",
      "pos": "pos",
      "ot_control": "ot",
      "security": "security"
    }
  },
  "redundancy": {
    "levels": {
      "false": {"edge_devices": 1, "dual_isp": false, "stacking": false, "core_pair": false},
      "basic": {"edge_devices": 1, "dual_isp": true, "stacking": false, "core_pair": false},
      "high": {"edge_devices": 2, "dual_isp": true, "stacking": true, "core_pair": true},
      "mission_critical": {"edge_devices": 2, "dual_isp": true, "stacking": true, "core_pair": true, "diverse_paths": true}
    },
    "critical_services_raise_minimum_to": "high"
  },
  "budget": {
    "level_multipliers": {"low": 0.8, "medium": 1.0, "high": 1.25},
    "conflict_rules": [
      {
        "id": "BUD-001",
        "condition": "budget_level low with high or mission_critical redundancy",
        "message": "Budget low conflicts with requested availability; propose phased redundancy."
      },
      {
        "id": "BUD-002",
        "condition": "budget_usd below rough bill of materials",
        "message": "Numeric budget below estimated design cost; reduce scope or phase deployment."
      }
    ]
  },
  "rule_catalog": [
    {"id": "WIFI-001", "name": "AP capacity", "logic": "AP count by capacity = ceil(concurrent wireless clients / target clients per AP adjusted by environment)."},
    {"id": "WIFI-002", "name": "AP coverage", "logic": "AP count by coverage = ceil(area_m2 / adjusted coverage per AP)."},
    {"id": "WIFI-003", "name": "Minimum per floor", "logic": "AP count must be at least min_ap_per_floor * floors."},
    {"id": "EDGE-001", "name": "Edge throughput", "logic": "Select the smallest edge router/firewall tier whose throughput and client capacity exceed requirements."},
    {"id": "SW-001", "name": "Access switching", "logic": "Switch ports include wired endpoints plus AP uplinks plus reserve."},
    {"id": "SEG-001", "name": "Guest isolation", "logic": "Guest traffic must be isolated from corporate networks."},
    {"id": "SEG-002", "name": "Device isolation", "logic": "IoT, voice, camera, OT and server traffic need dedicated VLANs when present."},
    {"id": "RED-001", "name": "Availability", "logic": "High or mission-critical redundancy requires dual WAN and HA edge devices."},
    {"id": "QOS-001", "name": "Critical traffic", "logic": "High or critical traffic and voice/video services require QoS and roaming controls."},
    {"id": "BUD-001", "name": "Budget conflict", "logic": "Low budget is incompatible with high availability unless deployment is phased."}
  ]
}
