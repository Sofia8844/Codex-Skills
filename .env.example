NODE_ENV=production
PORT=3000
RESTART_POLICY=unless-stopped

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=codex-jobs-postgres
POSTGRES_USER=codex
POSTGRES_PASSWORD=codex
POSTGRES_DB=codex_jobs
POSTGRES_PORT=5432
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=10

RABBITMQ_IMAGE=rabbitmq:3.13-management
RABBITMQ_CONTAINER_NAME=codex-jobs-rabbitmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PREFETCH=1
RABBITMQ_CONNECT_RETRIES=10
RABBITMQ_CONNECT_DELAY_MS=3000
RABBITMQ_HEALTHCHECK_INTERVAL=10s
RABBITMQ_HEALTHCHECK_TIMEOUT=5s
RABBITMQ_HEALTHCHECK_RETRIES=10

MAILHOG_IMAGE=mailhog/mailhog:v1.0.1
MAILHOG_CONTAINER_NAME=codex-jobs-mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

API_CONTAINER_NAME=codex-jobs-api
SKILL_WORKER_CONTAINER_NAME=codex-jobs-skill-worker
EMAIL_WORKER_CONTAINER_NAME=codex-jobs-email-worker

DATABASE_URL=postgresql://codex:codex@postgres:5432/codex_jobs

SKILL_JOBS_QUEUE=skill_jobs
EMAIL_JOBS_QUEUE=email_jobs

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@codex.local

PROJECT_ROOT=/usr/src/app
MAX_PROCESS_OUTPUT_CHARS=20000
